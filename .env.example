# Environment variables for development
# Copy this file to .env and fill in your actual values

# Database connection (using Supabase pooler)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct database connection
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Cloudinary configuration
CLOUDINARY_URL="cloudinary://[API_KEY]:[API_SECRET]@[CLOUD_NAME]"

# Server port
PORT=3000

# Supabase configuration
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# SMTP Hostinger email configuration
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="marketing@ilavioo.com"
SMTP_PASS="your-email-password"
CONTACT_FROM_EMAIL="marketing@ilavioo.com"
CONTACT_TO_EMAIL="marketing@ilavioo.com"

# CORS origin (set to your frontend URL in production)
CORS_ORIGIN="*"

# Node environment
NODE_ENV="development"
